NODE_ENV=production

PORT=3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=broker_db
DB_CONNECTION_LIMIT=10
OMS_CONFIG_CACHE_TTL_MS=300000

# Fernet key used to decrypt oms_endpoints.encrypted_password.
APP_ENCRYPTION_KEY=

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

CRON_SCHEDULE=*/2 * * * *

LOG_LEVEL=info

REQUEST_TIMEOUT_MS=30000
TOKEN_REFRESH_BUFFER_MS=60000
