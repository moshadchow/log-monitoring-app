NODE_ENV=production

PORT=3000

OMS_API_ENDPOINTS=https://prod-oms-api-1.xfltrade.com:20121,https://prod-oms-api-11.xfltrade.com:20121
# OMS_BASE_URL is still supported as a single-endpoint fallback.
# OMS_BASE_URL=https://prod-oms-api-1.xfltrade.com:20121

OMS_USERNAME=your-oms-username
OMS_PASSWORD=your-oms-password
OMS_DEVICE_ID=my-device-id-01
OMS_MFA_KEY=
OMS_MFA_CODE=
OMS_APP_TYPE=1

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

CRON_SCHEDULE=*/2 * * * *

LOG_LEVEL=info

REQUEST_TIMEOUT_MS=30000
TOKEN_REFRESH_BUFFER_MS=60000
