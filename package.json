{
  "name": "oms-log-monitoring-service",
  "version": "1.0.0",
  "description": "OMS Log Monitoring & Discord Notification Service",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "pm2:start": "pm2 start src/server.js --name oms-log-monitor",
    "pm2:stop": "pm2 stop oms-log-monitor",
    "pm2:restart": "pm2 restart oms-log-monitor",
    "pm2:logs": "pm2 logs oms-log-monitor"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "axios-retry": "^4.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "fernet": "^0.4.0",
    "mysql2": "^3.11.0",
    "node-cron": "^3.0.3",
    "winston": "^3.15.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
